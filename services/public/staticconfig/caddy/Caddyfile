{ # Global options block. Entirely optional, https is on by default
  email {$EMAIL} # Optional email key for lets encrypt
  #debug # this is optional; makes Caddy log more details

  admin 0.0.0.0:2019


  order crowdsec first # this ensures that the CrowdSec module is executed before any other HTTP handlers
  order crowdsec before respond

  crowdsec {
    api_url http://crowdsec:8080/ # the URL where your CrowdSec LAPI can be reached. Caddy connects directly, so use the default port 8080
    api_key {$BOUNCER_CADDY_TOKEN} # the secret API key for the bouncer to authenticate against LAPI
    ticker_interval 30s # how often to poll the LAPI for updated decisions
  }  
      
      
}

############
# Snippets #
############
(headers) {
	header {
    -server #anonymizes Caddy

    # disable FLoC tracking
    Permissions-Policy interest-cohort=()

    # enable HSTS
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Docs | Content Security Policy https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Content-Security-Policy
    # Docs | Referrer Policy https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Referrer-Policy

    # Control how much referrer information is shared
    #Referrer-Policy "no-referrer-when-downgrade"

    X-Content-Type-Options "nosniff" # disable clients from sniffing the media type

    # Prevent the site from being embedded in an iframe (Anti-Clickjacking)
    X-Frame-Options DENY

    # Basic protection against XSS
    #X-XSS-Protection "1; mode=block"
    header_up X-Real-IP {vars.realip}
	}
}

(main) {
  crowdsec
  
  respond /robots.txt 200 {
    body "User-agent: *
    Disallow: /
    
    User-agent: AdsBot-Google
    Disallow: /

    User-agent: AdsBot-Google-Mobile
    Disallow: /"

    close
  }

  encode zstd gzip

  log {
    level ERROR
    output file {$LOG_FILE} {
      roll_size 3MiB
      roll_keep 5
      roll_keep_for 48h
    }
    format json
  }
}

(internal-only) {
	@external not remote_ip private_ranges
	abort @external
}


(voidauth) {
  @external not remote_ip private_ranges

  forward_auth @external voidauth:3000 {
      uri /api/authz/forward-auth
      copy_headers Remote-User Remote-Groups Remote-Name Remote-Email x-voidauth-interaction x-voidauth-resume x-voidauth-session
  }
}

############
# Routing  #
############

# import *.caddy ## try this while storing individual sites in *.caddy files

localhost {
  import main

  respond "Hello, world!"
}

{$DOMAIN} {
  import headers
  import main

  # SSL Cert via Duckdns build
  tls {
    dns duckdns {$DUCKDNS_API_TOKEN}
  }

  respond "Look at me"
  # System Status page
  reverse_proxy /status/* uptime-kuma:3001
}

www.{$DOMAIN} {
  redir {$DOMAIN}{uri}
}

books.{$DOMAIN} {
  import headers
  import main

  reverse_proxy grimmory:6060
}

ghs.{$DOMAIN} {
  import headers
  import main
  import voidauth

  reverse_proxy gloomhaven:80
}

ghs-server.{$DOMAIN} {
  import headers
  import main

  reverse_proxy gloomhaven-server:8080

  @websockets {
    header Connection *Upgrade*
    header Upgrade websocket
    header Access-Control-Allow-Origin ghs.{$DOMAIN}
    header Access-Control-Allow-Origin gloomhaven-secretary.de
  }
  reverse_proxy @websockets gloomhaven-server:8080
}

grist.{$DOMAIN} {
  import headers
  import main

  reverse_proxy grist:8484
}

immich.{$DOMAIN} {
  import headers
  import main

  reverse_proxy immich_public-proxy:3000
}

jelly.{$DOMAIN} {
  import headers
  import main

  reverse_proxy jellyfin:8096
}

meet.{$DOMAIN} {
  import headers
  import main

  reverse_proxy rallly:3000
}

oath.{$DOMAIN} {
  import headers
  import main
  import voidauth

  root * /www/oathsworn
	file_server {
		hide /oathsworn-webapp /docker .git
	}
}

recipe.{$DOMAIN} {
  import headers
  import main

  handle_path /media/* {
			root * /www/tandoor
			file_server
		}

  reverse_proxy tandoor:80
}

request.{$DOMAIN} {
  import headers
  import main

  reverse_proxy jellyseerr:5055
}

status.{$DOMAIN} {
  import headers
  import main

  reverse_proxy uptime-kuma:3001
}

void.{$DOMAIN} {
  import headers
  import main

  reverse_proxy voidauth:3000
}



